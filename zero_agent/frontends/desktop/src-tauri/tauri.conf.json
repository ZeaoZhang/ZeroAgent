{
  "productName": "ZeroAgent",
  "version": "0.1.0",
  "identifier": "com.zeroagent.desktop",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ZeroAgent",
        "label": "main",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "visible": false,
        "url": "loading.html"
      },
      {
        "title": "ZeroAgent — Setup",
        "label": "setup",
        "width": 600,
        "height": 580,
        "resizable": false,
        "visible": false,
        "center": true,
        "url": "fallback.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
  }
}
